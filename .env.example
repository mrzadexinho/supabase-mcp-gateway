# Environment variables for Supabase MCP Gateway
# Copy to .env and fill in your values

# Required: Your Supabase instance URL
SUPABASE_URL=https://supabase.yourdomain.com

# Required: Supabase anonymous key
SUPABASE_ANON_KEY=your-anon-key-here

# Required: Supabase service role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Required: Direct PostgreSQL connection string
# Use the internal Docker hostname if on same network
DATABASE_URL=postgresql://postgres:password@supabase-db-container:5432/postgres

# Optional: Server port (default: 3000)
PORT=3000
